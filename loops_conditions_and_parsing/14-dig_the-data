#!/usr/bin/env bash
# Group by IP and HTTP status code, count occurrences, and sort properly
awk '
{
  # Count occurrences of each IP + HTTP code pair
  counts[$1" "$9]++
}
END {
  # Sort by count descending, then by IP, then by code
  PROCINFO["sorted_in"] = "@val_num_desc"
  for (key in counts) {
    print counts[key], key
  }
}
' apache-access.log
